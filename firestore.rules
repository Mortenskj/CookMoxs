rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: recipes
    // Document ID: {recipeId}
    // Fields:
    //   - id: string (required) - Unique identifier for the recipe
    //   - title: string (required) - Title of the recipe
    //   - description: string (optional) - Description of the recipe
    //   - servings: number (required) - Number of servings
    //   - folder: string (optional) - Folder name where the recipe is saved
    //   - folderId: string (optional) - ID of the folder
    //   - ingredients: list (required) - List of ingredients
    //   - steps: list (required) - List of steps
    //   - authorUID: string (required) - The UID of the user who created the recipe
    //   - createdAt: string (required) - Timestamp when the recipe was created
    //
    // Collection: folders
    // Document ID: {folderId}
    // Fields:
    //   - id: string (required) - Unique identifier for the folder
    //   - name: string (required) - Name of the folder
    //   - ownerUID: string (required) - UID of the owner
    //   - sharedWith: list (optional) - List of sharing objects {uid, email, role}
    //   - editorUids: list (optional) - List of UIDs with editor access
    //   - viewerUids: list (optional) - List of UIDs with viewer access
    //   - isDefault: bool (optional) - Whether it's a default folder
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUID;
    }

    function uidUnchanged() {
      return !('authorUID' in request.resource.data) || request.resource.data.authorUID == request.auth.uid;
    }

    function uidNotModified() {
      return !('authorUID' in request.resource.data) || request.resource.data.authorUID == resource.data.authorUID;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidRecipe(data) {
      return hasRequiredFields(['id', 'title', 'servings', 'ingredients', 'steps', 'authorUID', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.servings is number && data.servings > 0 &&
             data.ingredients is list && data.ingredients.size() <= 100 &&
             data.steps is list && data.steps.size() <= 100 &&
             data.authorUID is string && data.authorUID.size() > 0 && data.authorUID.size() < 100 &&
             data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() < 50 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('folder' in data) || (data.folder is string && data.folder.size() <= 100)) &&
             (!('folderId' in data) || (data.folderId is string && data.folderId.size() <= 100));
    }

    function isValidFolder(data) {
      return hasRequiredFields(['id', 'name', 'ownerUID']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.ownerUID is string && data.ownerUID.size() > 0 && data.ownerUID.size() < 100 &&
             (!('sharedWith' in data) || data.sharedWith is list) &&
             (!('editorUids' in data) || data.editorUids is list) &&
             (!('viewerUids' in data) || data.viewerUids is list) &&
             (!('isDefault' in data) || data.isDefault is bool);
    }

    function isFolderOwner(folderId) {
      return isAuthenticated() && get(/databases/$(database)/documents/folders/$(folderId)).data.ownerUID == request.auth.uid;
    }

    function hasFolderAccess(folderId, requiredRole) {
      let folder = get(/databases/$(database)/documents/folders/$(folderId)).data;
      let isOwner = folder.ownerUID == request.auth.uid;
      let isEditor = 'editorUids' in folder && request.auth.uid in folder.editorUids;
      let isViewer = 'viewerUids' in folder && request.auth.uid in folder.viewerUids;
      
      return isOwner || isEditor || (requiredRole == 'viewer' && isViewer);
    }

    match /folders/{folderId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerUID == request.auth.uid || 
        ('editorUids' in resource.data && request.auth.uid in resource.data.editorUids) ||
        ('viewerUids' in resource.data && request.auth.uid in resource.data.viewerUids)
      );
      allow create: if isAuthenticated() && isValidFolder(request.resource.data) && request.resource.data.ownerUID == request.auth.uid;
      allow update: if isAuthenticated() && isValidFolder(request.resource.data) && (
        resource.data.ownerUID == request.auth.uid || 
        ('editorUids' in resource.data && request.auth.uid in resource.data.editorUids)
      );
      allow delete: if isAuthenticated() && resource.data.ownerUID == request.auth.uid;
    }

    match /recipes/{recipeId} {
      allow read: if isAuthenticated() && (resource.data.authorUID == request.auth.uid || ('folderId' in resource.data && resource.data.folderId != null && hasFolderAccess(resource.data.folderId, 'viewer')));
      allow create: if isAuthenticated() && isValidRecipe(request.resource.data) && uidUnchanged() && (!('folderId' in request.resource.data) || request.resource.data.folderId == null || hasFolderAccess(request.resource.data.folderId, 'editor'));
      allow update: if isAuthenticated() && isValidRecipe(request.resource.data) && (
        (resource.data.authorUID == request.auth.uid && uidNotModified()) || 
        ('folderId' in resource.data && resource.data.folderId != null && isFolderOwner(resource.data.folderId))
      ) && (!('folderId' in request.resource.data) || request.resource.data.folderId == null || hasFolderAccess(request.resource.data.folderId, 'editor'));
      allow delete: if isAuthenticated() && (resource.data.authorUID == request.auth.uid || ('folderId' in resource.data && resource.data.folderId != null && isFolderOwner(resource.data.folderId)));
    }
  }
}
