# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# GITHUB_TOKEN: Optional GitHub Personal Access Token for higher rate limits.
GITHUB_TOKEN=

# OBSERVER_ENABLED: Optional. Set to "true" to keep hidden observer logging enabled on hosted environments.
OBSERVER_ENABLED=

# OBSERVER_EXPORT_TOKEN: Optional but recommended outside local dev.
# If set, hidden observer endpoints require this token in the x-observer-token header.
OBSERVER_EXPORT_TOKEN=

# OBSERVER_PERSIST_TO_DISK: Optional. Set to "false" to disable local JSONL persistence.
OBSERVER_PERSIST_TO_DISK=
