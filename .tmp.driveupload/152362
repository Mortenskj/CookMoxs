services:
  - type: web
    name: cookmoxs-ai-app
    env: node
    plan: free
    buildCommand: |
      npm install
      npm run build
    startCommand: npm start
    envVars:
      # Server-side Gemini key. Configure this in Render before using AI routes.
      - key: GEMINI_API_KEY
        sync: false
      # Express serves the built frontend from dist/ in production.
      - key: NODE_ENV
        value: production
